{
  "name": "raptur",
  "packageManager": "yarn@4.5.3",
  "version": "0.1.0",
  "description": "Composable, zero-dependency HTTP router for Node.js with prehistoric power 🦖",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "yarn build",
    "prepublishOnly": "yarn typecheck && yarn test && yarn lint"
  },
  "keywords": [
    "router",
    "nodejs",
    "typescript",
    "http",
    "server",
    "web",
    "middleware",
    "composable",
    "decorators"
  ],
  "author": "Nana Adjei Manu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nkwadwo/raptur.git"
  },
  "bugs": {
    "url": "https://github.com/nkwadwo/raptur/issues"
  },
  "homepage": "https://github.com/nkwadwo/raptur#readme",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "files": [
    "dist/**/*"
  ]
}
