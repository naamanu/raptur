{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "rootDir": "./src",
    "lib": ["ES2022"],
    "types": ["node", "jest"],
    "moduleResolution": "nodenext",
    // Standard (TC39) decorators: enabled by the *absence* of
    // experimentalDecorators. Do not add experimentalDecorators/emitDecoratorMetadata.
    "useDefineForClassFields": true,
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
